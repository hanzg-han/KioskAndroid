<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 基础主题 -->
    <style name="Theme.Kiosk" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <!-- 全屏 Kiosk 主题 -->
    <style name="Theme.Kiosk.Fullscreen" parent="Theme.Kiosk">
        <item name="android:windowBackground">@android:color/white</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
    </style>

    <!-- 透明主题（定时亮屏 Activity 使用） -->
    <style name="Theme.Kiosk.Transparent" parent="Theme.Kiosk">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowAnimationStyle">@null</item>
    </style>

    <!-- 底部导航按钮样式 -->
    <style name="NavButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:background">#DDDDDD</item>
        <item name="android:textColor">#333333</item>
        <item name="android:textSize">14sp</item>
        <item name="android:minWidth">0dp</item>
    </style>

    <style name="NavButton.Exit" parent="NavButton">
        <item name="android:background">#E57373</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>
</resources>
