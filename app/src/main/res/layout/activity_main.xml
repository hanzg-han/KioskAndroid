<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:keepScreenOn="true"
    android:orientation="vertical">

    <!-- 主内容区域：左边视频+识别，右边日志 -->
    <LinearLayout
        android:id="@+id/content_area"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:padding="4dp">

        <!-- 左边：视频 + 语音识别显示 -->
        <LinearLayout
            android:id="@+id/left_panel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="7"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="4dp">

            <!-- 唤醒/休眠状态 -->
            <TextView
                android:id="@+id/tv_asr_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="语音识别就绪"
                android:textColor="#999999"
                android:textSize="14sp" />

            <!-- 视频显示区域 -->
            <ImageView
                android:id="@+id/iv_video"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="4dp"
                android:background="#000000"
                android:contentDescription="视频画面"
                android:scaleType="fitCenter" />

            <!-- 识别文本 -->
            <TextView
                android:id="@+id/tv_asr_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#F8F8F8"
                android:gravity="center"
                android:maxLines="3"
                android:minHeight="36dp"
                android:padding="4dp"
                android:text=""
                android:textColor="#333333"
                android:textSize="18sp" />

            <!-- NLP / 语义回答 -->
            <TextView
                android:id="@+id/tv_nlp_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:maxLines="2"
                android:minHeight="28dp"
                android:padding="2dp"
                android:text=""
                android:textColor="#1976D2"
                android:textSize="14sp" />

            <!-- 手动唤醒按钮 -->
            <Button
                android:id="@+id/btn_wakeup"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:layout_marginTop="2dp"
                android:background="#64B5F6"
                android:minWidth="100dp"
                android:text="手动唤醒"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- 右边：接口日志消息框 -->
        <LinearLayout
            android:id="@+id/right_panel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="3"
            android:background="#1E1E1E"
            android:orientation="vertical"
            android:padding="4dp">

            <TextView
                android:id="@+id/tv_log_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="2dp"
                android:text="接口日志"
                android:textColor="#CCCCCC"
                android:textSize="12sp"
                android:textStyle="bold" />

            <ScrollView
                android:id="@+id/sv_log"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fillViewport="true">

                <TextView
                    android:id="@+id/tv_log_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="4dp"
                    android:text=""
                    android:textColor="#AAAAAA"
                    android:textSize="10sp"
                    android:typeface="monospace" />
            </ScrollView>
        </LinearLayout>
    </LinearLayout>

    <!-- 定时控制栏 -->
    <LinearLayout
        android:id="@+id/schedule_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#F0F0F0"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp">

        <!-- 行1: 定时息屏/亮屏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_schedule_info"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="息屏: 未设置 | 亮屏: 未设置"
                android:textColor="#666666"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btn_set_screen_off"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:background="#CCCCCC"
                android:minWidth="0dp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:text="息屏"
                android:textColor="#333333"
                android:textSize="11sp" />

            <Button
                android:id="@+id/btn_set_screen_on"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:background="#CCCCCC"
                android:layout_marginStart="3dp"
                android:minWidth="0dp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:text="亮屏"
                android:textColor="#333333"
                android:textSize="11sp" />

            <Button
                android:id="@+id/btn_clear_schedule"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:layout_marginStart="3dp"
                android:background="#E57373"
                android:minWidth="0dp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:text="清除"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- 行2: 自更新 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_update_info"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="更新: 未配置"
                android:textColor="#999999"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btn_update_config"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:background="#BBBBBB"
                android:minWidth="0dp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:text="配置"
                android:textColor="#333333"
                android:textSize="11sp" />

            <Button
                android:id="@+id/btn_check_update"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:layout_marginStart="3dp"
                android:background="#81C784"
                android:minWidth="0dp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:text="检查更新"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- 底部导航栏 -->
    <LinearLayout
        android:id="@+id/nav_bar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#EEEEEE"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <Button
            android:id="@+id/btn_navbar"
            style="@style/NavButton"
            android:text="导航栏" />

        <Button
            android:id="@+id/btn_exit"
            style="@style/NavButton.Exit"
            android:text="退出" />
    </LinearLayout>

</LinearLayout>
