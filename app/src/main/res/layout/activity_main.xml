<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:keepScreenOn="true"
    android:orientation="vertical">

    <!-- 主内容区域 -->
    <FrameLayout
        android:id="@+id/content_area"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <WebView
            android:id="@+id/webview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Kiosk 模式已启动\n状态栏下拉已禁用"
            android:textAlignment="center"
            android:textColor="#333333"
            android:textSize="24sp"
            android:lineSpacingExtra="8dp" />
    </FrameLayout>

    <!-- 定时控制栏 -->
    <LinearLayout
        android:id="@+id/schedule_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#F0F0F0"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp">

        <!-- 行1: 定时息屏/亮屏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_schedule_info"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="息屏: 未设置 | 亮屏: 未设置"
                android:textColor="#666666"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btn_set_screen_off"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:background="#CCCCCC"
                android:minWidth="0dp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:text="息屏"
                android:textColor="#333333"
                android:textSize="11sp" />

            <Button
                android:id="@+id/btn_set_screen_on"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:background="#CCCCCC"
                android:layout_marginStart="3dp"
                android:minWidth="0dp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:text="亮屏"
                android:textColor="#333333"
                android:textSize="11sp" />

            <Button
                android:id="@+id/btn_clear_schedule"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:layout_marginStart="3dp"
                android:background="#E57373"
                android:minWidth="0dp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:text="清除"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- 行2: 自更新 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_update_info"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="更新: 未配置"
                android:textColor="#999999"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btn_update_config"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:background="#BBBBBB"
                android:minWidth="0dp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:text="配置"
                android:textColor="#333333"
                android:textSize="11sp" />

            <Button
                android:id="@+id/btn_check_update"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:layout_marginStart="3dp"
                android:background="#81C784"
                android:minWidth="0dp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:text="检查更新"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- 底部导航栏 -->
    <LinearLayout
        android:id="@+id/nav_bar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#EEEEEE"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <Button
            android:id="@+id/btn_back"
            style="@style/NavButton"
            android:text="← 返回" />

        <Button
            android:id="@+id/btn_home"
            style="@style/NavButton"
            android:text="主页" />

        <Button
            android:id="@+id/btn_refresh"
            style="@style/NavButton"
            android:text="刷新" />

        <Button
            android:id="@+id/btn_navbar"
            style="@style/NavButton"
            android:text="导航栏" />

        <Button
            android:id="@+id/btn_exit"
            style="@style/NavButton.Exit"
            android:text="退出" />
    </LinearLayout>

</LinearLayout>
